---
import { site } from '../data/site';
import SocialIcon from './SocialIcon.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle bg-surface-raised/60">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-5 py-10 md:flex-row md:px-8">
    <div class="text-center md:text-left">
      <p class="font-display font-semibold text-foreground">{site.name}</p>
      <p class="mt-1 max-w-xs text-sm text-muted">{site.title} · {site.location}</p>
    </div>

    <div class="flex items-center gap-2">
      {
        site.social.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface text-muted shadow-soft transition-all hover:border-accent/40 hover:text-accent-dim"
            aria-label={link.label}
          >
            <SocialIcon icon={link.icon} />
          </a>
        ))
      }
    </div>

    <p class="text-center text-sm text-muted md:text-right">
      © {year} {site.name}
    </p>
  </div>
</footer>
