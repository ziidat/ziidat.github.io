---
import { site } from '../data/site';
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border-subtle bg-surface-raised/75 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 md:h-[4.25rem] md:px-8">
    <a
      href={import.meta.env.BASE_URL}
      class="font-display text-lg font-semibold tracking-tight text-foreground transition-colors hover:text-accent-dim"
    >
      {site.name.split(' ')[0]}<span class="text-accent-dim">.</span>
    </a>

    <nav class="hidden items-center gap-0.5 md:flex" aria-label="Navigasi utama">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-3.5 py-2 text-sm text-muted transition-colors hover:bg-surface-overlay hover:text-foreground"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="#kontak" class="btn-primary hidden !px-4 !py-2 sm:inline-flex">
        Hubungi saya
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface-raised text-muted transition-colors hover:border-accent/40 hover:text-foreground md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Buka menu"
      >
        <svg id="icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-border-subtle bg-surface-raised md:hidden"
    hidden
  >
    <nav class="flex flex-col gap-1 px-5 py-4" aria-label="Navigasi mobile">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="mobile-nav-link rounded-xl px-3 py-3 text-muted transition-colors hover:bg-surface-overlay hover:text-foreground"
          >
            {item.label}
          </a>
        ))
      }
      <a href="#kontak" class="mobile-nav-link btn-primary mt-2 justify-center">
        Hubungi saya
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function setOpen(open: boolean) {
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Tutup menu' : 'Buka menu');
    menu?.classList.toggle('hidden', !open);
    menu?.toggleAttribute('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') !== 'true';
    setOpen(open);
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
