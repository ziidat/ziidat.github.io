---
import { site } from '../data/site';
import SectionHeading from './SectionHeading.astro';
import CertificationGallery from './CertificationGallery.astro';

const resultStyles: Record<string, string> = {
  Gold: 'bg-peach/30 text-foreground border-peach/40',
  Silver: 'bg-surface-overlay text-foreground border-border',
  Bronze: 'bg-violet/15 text-foreground border-violet/30',
  '2nd Runner Up': 'bg-accent/20 text-foreground border-accent/30',
  Participant: 'bg-mint/15 text-muted border-mint/30',
  Ongoing: 'bg-mint/25 text-accent-dim border-mint/40',
};
---

<section id="sertifikasi" class="scroll-mt-24 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <SectionHeading
      eyebrow="Sertifikasi & Penghargaan"
      title="Kompetensi, HAKI & inovasi"
      description="Sertifikasi profesional, hak cipta, dan penghargaan inovasi tingkat perusahaan."
    />

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="card-shine bg-mint/10 p-6 md:p-8">
        <h3 class="font-display text-lg font-semibold text-foreground">Sertifikasi</h3>
        <ul class="mt-5 space-y-4">
          {
            site.certifications.map((cert) => (
              <li class="flex gap-3 text-sm leading-relaxed text-muted">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-mint" aria-hidden="true"></span>
                {cert}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="card-shine bg-violet/10 p-6 md:p-8">
        <h3 class="font-display text-lg font-semibold text-foreground">Hak Kekayaan Intelektual</h3>
        <ul class="mt-5 space-y-4">
          {
            site.intellectualProperty.map((ip) => (
              <li>
                <a
                  href={ip.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-xl border border-border-subtle bg-surface-raised p-4 shadow-soft transition-all hover:border-accent/30 hover:shadow-soft-lg"
                >
                  <p class="font-medium text-foreground transition-colors group-hover:text-accent-dim">{ip.title}</p>
                  <p class="mt-1 text-sm text-muted">{ip.type}</p>
                  <p class="mt-2 text-xs font-medium text-accent-dim">{ip.year}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <CertificationGallery />

    <div class="card-shine mt-6 bg-surface-overlay/50 p-6 md:p-8">
      <h3 class="font-display text-lg font-semibold text-foreground">Penghargaan Inovasi</h3>
      <p class="mt-2 text-sm text-muted">
        PSS GKM, Innovation Award, dan IAKA — {site.innovationAwards.length} partisipasi (2019–2026)
      </p>

      <ul class="mt-6 space-y-3">
        {
          site.innovationAwards.map((award) => {
            const badgeClass =
              resultStyles[award.result] ?? 'bg-surface-overlay text-muted border-border';
            return (
              <li class="rounded-xl border border-border-subtle bg-surface-raised p-4 shadow-soft md:p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <span class="rounded-full bg-accent/15 px-2.5 py-0.5 text-xs font-semibold text-accent-dim">
                    {award.event} · {award.year}
                  </span>
                  <span
                    class:list={[
                      'inline-flex shrink-0 rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide',
                      badgeClass,
                    ]}
                  >
                    {award.result}
                  </span>
                </div>
                <p class="mt-3 font-medium text-foreground">{award.project}</p>
                {'description' in award && award.description && (
                  <p class="mt-2 text-sm leading-relaxed text-muted">{award.description}</p>
                )}
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</section>
