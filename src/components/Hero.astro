---
import { site } from '../data/site';
import SocialIcon from './SocialIcon.astro';

const base = import.meta.env.BASE_URL;
const photoJpg = `${base}profile.jpg`;
const photoFallback = `${base}profile.svg`;
---

<section class="relative overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="pointer-events-none absolute inset-0 grid-pattern" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_minmax(240px,320px)] lg:gap-16">
      <div>
        <div class="reveal flex flex-wrap items-center gap-3">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-raised px-3.5 py-1.5 text-sm text-muted shadow-soft"
          >
            <span class="h-2 w-2 rounded-full bg-mint" aria-hidden="true"></span>
            {site.availability}
          </span>
        </div>

        <h1
          class="reveal reveal-delay-1 mt-8 font-display text-4xl font-bold leading-[1.12] tracking-tight text-foreground md:text-5xl lg:text-[3.5rem]"
        >
          Halo, saya <span class="text-gradient">{site.name}</span>
          <span class="mt-2 block text-xl font-medium text-muted md:text-2xl lg:text-3xl">
            {site.title}
          </span>
        </h1>

        <p class="reveal reveal-delay-2 mt-6 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
          {site.tagline}
        </p>

        <div class="reveal reveal-delay-3 mt-10 flex flex-wrap items-center gap-3">
          <a href="#proyek" class="btn-primary gap-2">
            Lihat proyek
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-raised px-6 py-3 text-sm font-semibold text-foreground shadow-soft transition-all hover:border-accent/40 hover:bg-surface-overlay"
          >
            Kirim email
          </a>
        </div>

        <div class="reveal reveal-delay-3 mt-12 flex flex-wrap items-center gap-3">
          {
            site.social.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-11 w-11 items-center justify-center rounded-full border border-border bg-surface-raised text-muted shadow-soft transition-all hover:border-accent/40 hover:text-accent-dim"
                aria-label={link.label}
              >
                <SocialIcon icon={link.icon} />
              </a>
            ))
          }
        </div>
      </div>

      <div class="reveal reveal-delay-2 mx-auto w-full max-w-xs lg:max-w-none lg:justify-self-end">
        <figure class="relative">
          <div
            class="pointer-events-none absolute -inset-3 rounded-4xl bg-linear-to-br from-accent/40 via-violet/30 to-mint/40 opacity-60 blur-xl dark:opacity-50"
            aria-hidden="true"
          ></div>
          <div
            class="relative overflow-hidden rounded-[1.75rem] border-4 border-surface-raised bg-surface-raised shadow-soft-lg"
          >
            <picture>
              <source srcset={photoJpg} type="image/jpeg" />
              <img
                src={photoFallback}
                alt={site.photo.alt}
                width="400"
                height="400"
                class="aspect-square w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </picture>
          </div>
        </figure>
      </div>
    </div>

    <dl
      class="reveal reveal-delay-3 mt-16 grid grid-cols-2 gap-4 border-t border-border-subtle pt-10 sm:grid-cols-2 lg:grid-cols-4 md:gap-6"
    >
      {
        site.stats.map((stat) => (
          <div class="rounded-2xl border border-border-subtle bg-surface-raised/80 p-4 shadow-soft md:p-5">
            <dt class="font-display text-2xl font-semibold text-accent-dim md:text-3xl">{stat.value}</dt>
            <dd class="mt-1 text-sm text-muted">{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
