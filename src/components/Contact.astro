---
import { site } from '../data/site';
import SectionHeading from './SectionHeading.astro';
import SocialIcon from './SocialIcon.astro';
---

<section id="kontak" class="scroll-mt-24 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div
      class="relative overflow-hidden rounded-3xl border border-border bg-surface-raised p-8 shadow-soft-lg md:p-14"
    >
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-accent/15 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -bottom-12 -left-12 h-40 w-40 rounded-full bg-violet/15 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="relative grid gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <SectionHeading
            eyebrow="Kontak"
            title="Mari terhubung"
            description="Tertarik berkolaborasi, diskusi proyek digital, atau kesempatan profesional? Hubungi saya melalui email atau telepon."
          />
        </div>

        <div class="flex flex-col justify-center gap-3">
          <a
            href={`mailto:${site.email}`}
            class="group flex items-center gap-4 rounded-2xl border border-border-subtle bg-surface p-5 transition-all hover:border-accent/30 hover:shadow-soft"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-accent/15 text-accent-dim">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </span>
            <span>
              <span class="block text-sm text-muted">Email</span>
              <span class="font-medium text-foreground transition-colors group-hover:text-accent-dim">
                {site.email}
              </span>
            </span>
          </a>

          <a
            href={site.phoneHref}
            class="group flex items-center gap-4 rounded-2xl border border-border-subtle bg-surface p-5 transition-all hover:border-accent/30 hover:shadow-soft"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-mint/25 text-foreground/70">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </span>
            <span>
              <span class="block text-sm text-muted">Telepon / WhatsApp</span>
              <span class="font-medium text-foreground transition-colors group-hover:text-accent-dim">
                {site.phoneHref}
              </span>
            </span>
          </a>

          <a
            href={site.portfolio}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-2xl border border-border-subtle bg-surface p-5 transition-all hover:border-accent/30 hover:shadow-soft"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-violet/20 text-foreground/70">
              <SocialIcon icon="portfolio" class="h-5 w-5" />
            </span>
            <span>
              <span class="block text-sm text-muted">Portfolio</span>
              <span class="font-medium text-foreground transition-colors group-hover:text-accent-dim">
                ziidat.github.io
              </span>
            </span>
          </a>

          <div class="mt-2 flex flex-wrap gap-2">
            {
              site.social.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-border bg-surface-raised px-4 py-2.5 text-sm text-muted shadow-soft transition-all hover:border-accent/30 hover:text-accent-dim"
                >
                  <SocialIcon icon={link.icon} class="h-4 w-4" />
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
