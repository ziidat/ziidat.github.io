---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-12 max-w-2xl md:mb-14">
  <p class="mb-3 text-sm font-medium tracking-wide text-accent-dim uppercase">{eyebrow}</p>
  <h2 class="font-display text-3xl font-semibold tracking-tight text-foreground md:text-4xl">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-lg leading-relaxed text-muted">{description}</p>
  )}
</div>
