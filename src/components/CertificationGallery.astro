---
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<div class="card-shine mt-6 bg-mint/10 p-6 md:p-8">
  <h3 class="font-display text-lg font-semibold text-foreground">Galeri Sertifikat</h3>
  <p class="mt-2 text-sm text-muted">
    Sertifikasi, penghargaan inovasi, dan dokumen HAKI.
  </p>

  <ul class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      site.certificationGallery.map((item, index) => {
        const src = `${base}${item.image}`;
        return (
          <li>
            <button
              type="button"
              class="cert-gallery-trigger group w-full cursor-zoom-in text-left"
              data-index={index}
              data-src={src}
              data-title={item.title}
            >
              <figure class="overflow-hidden rounded-xl border border-border-subtle bg-surface-raised shadow-soft transition-all group-hover:border-accent/30 group-hover:shadow-soft-lg">
                <div class="relative aspect-[4/3] bg-surface-overlay">
                  <img
                    src={src}
                    alt={item.title}
                    width="640"
                    height="480"
                    class="cert-gallery-img h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="cert-gallery-fallback absolute inset-0 hidden flex-col items-center justify-center gap-2 bg-surface-overlay p-4 text-center">
                    <svg
                      class="h-8 w-8 text-accent/50"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      ></path>
                    </svg>
                    <span class="text-xs text-muted">Gambar belum diunggah</span>
                  </div>
                </div>
                <figcaption class="border-t border-border-subtle px-3 py-3 text-sm font-medium leading-snug text-foreground">
                  {item.title}
                </figcaption>
              </figure>
            </button>
          </li>
        );
      })
    }
  </ul>
</div>

<dialog
  id="cert-lightbox"
  class="cert-lightbox fixed inset-0 z-[100] m-0 max-h-none max-w-none border-0 bg-transparent p-0 backdrop:bg-foreground/60 backdrop:backdrop-blur-sm open:flex open:items-center open:justify-center"
  aria-label="Pratinjau sertifikat"
>
  <div class="relative mx-4 flex max-h-[90vh] w-full max-w-3xl flex-col">
    <button
      type="button"
      id="cert-lightbox-close"
      class="absolute -top-12 right-0 rounded-full border border-border bg-surface-raised px-4 py-2 text-sm font-medium text-foreground shadow-soft transition-colors hover:border-accent/40"
    >
      Tutup
    </button>
    <div class="overflow-hidden rounded-2xl border border-border bg-surface-raised shadow-soft-lg">
      <img
        id="cert-lightbox-img"
        src=""
        alt=""
        class="max-h-[75vh] w-full object-contain bg-surface"
      />
      <p id="cert-lightbox-caption" class="border-t border-border-subtle px-4 py-3 text-sm font-medium text-foreground"></p>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('cert-lightbox') as HTMLDialogElement;
  const lightboxImg = document.getElementById('cert-lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('cert-lightbox-caption');
  const closeBtn = document.getElementById('cert-lightbox-close');

  document.querySelectorAll('.cert-gallery-img').forEach((img) => {
    img.addEventListener('error', () => {
      const imgEl = img as HTMLImageElement;
      imgEl.classList.add('hidden');
      imgEl.parentElement?.querySelector('.cert-gallery-fallback')?.classList.remove('hidden');
      imgEl.parentElement?.querySelector('.cert-gallery-fallback')?.classList.add('flex');
    });
  });

  function openLightbox(src: string, title: string) {
    if (!dialog || !lightboxImg || !lightboxCaption) return;
    lightboxImg.src = src;
    lightboxImg.alt = title;
    lightboxCaption.textContent = title;
    dialog.showModal();
  }

  function closeLightbox() {
    dialog?.close();
    if (lightboxImg) lightboxImg.src = '';
  }

  document.querySelectorAll('.cert-gallery-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-src');
      const title = btn.getAttribute('data-title');
      const img = btn.querySelector('.cert-gallery-img') as HTMLImageElement | null;
      if (!src || !title || img?.classList.contains('hidden')) return;
      openLightbox(src, title);
    });
  });

  closeBtn?.addEventListener('click', closeLightbox);

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) closeLightbox();
  });

  dialog?.addEventListener('cancel', closeLightbox);
</script>

<style>
  .cert-lightbox::backdrop {
    background: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .cert-lightbox[open] {
    animation: cert-fade-in 0.2s ease-out;
  }

  @keyframes cert-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
